<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/wine-dss"
         xmlns="http://example.org/wine-dss#">

<owl:Ontology rdf:about="http://example.org/wine-dss"/>

<owl:ObjectProperty rdf:about="#hasTypicalColor">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="#WineColor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTypicalBody">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="#WineBody"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTypicalSugar">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="#WineSugar"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasTypicalFlavor">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="#WineFlavor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#originatesFrom">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="#Country"/>

</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#canProduceColor">
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="#WineColor"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#hasVarietyName">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasSKU">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#isAromatic">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:domain rdf:resource="#WineVariety"/>
