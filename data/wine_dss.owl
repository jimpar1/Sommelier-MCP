<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#WineColor"/>
    <rdf:Description rdf:about="#WineBody"/>
    <rdf:Description rdf:about="#WineSugar"/>
    <rdf:Description rdf:about="#WineFlavor"/>
    <rdf:Description rdf:about="#Country"/>
    <rdf:Description rdf:about="#WineVariety"/>
  </owl:members>
</owl:AllDisjointClasses>

<!-- Disjoint variety subclasses on functional properties: a variety has exactly one
     typical colour, sugar and body, so these pairs can never overlap. The sugar/body
     halves use the pairing classes (DessertPairing ≡ Sweet, CheesePairing ≡ Full) since
     the standalone SweetVariety/FullBodiedVariety duplicates were removed. RedVariety is
     not disjoint with rosé membership (rosé varieties are red varieties that can also be
     vinified as rosé via canProduceColor). -->
<rdf:Description rdf:about="#RedVariety">
  <owl:disjointWith rdf:resource="#WhiteVariety"/>
</rdf:Description>

<rdf:Description rdf:about="#DryVariety">
  <owl:disjointWith rdf:resource="#DessertPairing"/>
</rdf:Description>


</rdf:RDF>
