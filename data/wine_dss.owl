</owl:Class>

<owl:Class rdf:about="#RedVariety">
  <rdfs:subClassOf rdf:resource="#WineVariety"/>
  <owl:equivalentClass>
    <owl:Class>
      <owl:intersectionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#WineVariety"/>
        <owl:Restriction>
          <owl:onProperty rdf:resource="#hasTypicalColor"/>
          <owl:hasValue rdf:resource="#Red"/>
        </owl:Restriction>
      </owl:intersectionOf>
    </owl:Class>
  </owl:equivalentClass>
</owl:Class>

